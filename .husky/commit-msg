#!/usr/bin/env sh

# Commit Message Linter
# Enforces Conventional Commits format: type(scope): subject
# Examples:
#   feat(auth): add OAuth2 support
#   fix(db): resolve migration conflict
#   docs: update README
#   refactor: simplify user validation

msg="$(cat "$1")"

# Check format: start with type(scope): or type: (or merge commit, revert, etc)
if ! echo "$msg" | grep -qE '^(feat|fix|docs|style|refactor|perf|test|ci|chore|revert)(\(.+\))?: .{1,}'; then
  echo ""
  echo "❌ Commit message must follow Conventional Commits format:"
  echo ""
  echo "   type(optional-scope): description"
  echo ""
  echo "Valid types: feat, fix, docs, style, refactor, perf, test, ci, chore, revert"
  echo ""
  echo "Examples:"
  echo "   feat(auth): add OAuth2 support"
  echo "   fix(db): resolve migration conflict"
  echo "   docs: update API reference"
  echo ""
  echo "Your message: $msg"
  echo ""
  exit 1
fi

exit 0

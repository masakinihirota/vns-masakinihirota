{
    "version": 1,
    "hooks": {
        "sessionStart": [
            {
                "type": "command",
                "powershell": "./scripts/hooks/pre-session-check.ps1",
                "bash": "./scripts/hooks/pre-session-check.sh",
                "cwd": ".",
                "timeoutSec": 30
            }
        ],
        "preToolUse": [
            {
                "type": "command",
                "powershell": "./scripts/hooks/pre-tool-security-check.ps1",
                "bash": "./scripts/hooks/pre-tool-security-check.sh",
                "cwd": ".",
                "timeoutSec": 15,
                "comment": "セキュリティ・品質チェック - 危険なコマンドをブロック"
            },
            {
                "type": "command",
                "powershell": "./scripts/hooks/pre-tool-audit-log.ps1",
                "bash": "./scripts/hooks/pre-tool-audit-log.sh",
                "cwd": ".",
                "timeoutSec": 5,
                "comment": "ツール使用をロギング"
            }
        ],
        "postToolUse": [
            {
                "type": "command",
                "powershell": "./scripts/hooks/post-tool-code-review.ps1",
                "bash": "./scripts/hooks/post-tool-code-review.sh",
                "cwd": ".",
                "timeoutSec": 20,
                "comment": "コード品質自動レビュー（edit/create 後の品質チェック）"
            },
            {
                "type": "command",
                "powershell": "./scripts/hooks/post-tool-result-log.ps1",
                "bash": "./scripts/hooks/post-tool-result-log.sh",
                "cwd": ".",
                "timeoutSec": 10,
                "comment": "ツール実行結果をロギング"
            }
        ],
        "userPromptSubmitted": [
            {
                "type": "command",
                "powershell": "./scripts/hooks/log-user-prompt.ps1",
                "bash": "./scripts/hooks/log-user-prompt.sh",
                "cwd": ".",
                "timeoutSec": 5,
                "comment": "ユーザープロンプトを監査ログに記録"
            }
        ],
        "sessionEnd": [
            {
                "type": "command",
                "powershell": "./scripts/hooks/post-session-report.ps1",
                "bash": "./scripts/hooks/post-session-report.sh",
                "cwd": ".",
                "timeoutSec": 30,
                "comment": "セッション終了レポート生成"
            }
        ],
        "errorOccurred": [
            {
                "type": "command",
                "powershell": "./scripts/hooks/error-occurred-log.ps1",
                "bash": "./scripts/hooks/error-occurred-log.sh",
                "cwd": ".",
                "timeoutSec": 5,
                "comment": "エラーイベントをログに記録"
            }
        ]
    }
}

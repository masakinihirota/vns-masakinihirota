# ============================================================================
# Environment Variables Template - Development
# ============================================================================
# Copy this file to .env.local and fill in your values
# ⚠️ Never commit .env.local to Git - it contains secrets!

# ============================================================================
# 1. Authentication (Better Auth)
# ============================================================================
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=<generate-with-openssl>
BETTER_AUTH_URL=http://localhost:3000

# Client-side auth URL (required for useSession hook)
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Authentication mode (development only)
# true: OAuth authentication  | false: Mock auth (skip OAuth)
# Uncomment one:
# USE_REAL_AUTH=true

# ============================================================================
# 2. Database
# ============================================================================
# Local PostgreSQL connection
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
DATABASE_URL=postgresql://user:password@localhost:5433/vns_db

# ============================================================================
# 3. OAuth Providers (Development)
# ============================================================================
# Google OAuth: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ============================================================================
# 4. Application URLs
# ============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================================
# 5. Optional Services
# ============================================================================
# Email service (Resend): https://resend.com/api-keys
# RESEND_API_KEY=

# Redis (production only): Vercel KV
# REDIS_URL=
# ============================================================================
# 6. Monitoring & Error Tracking (Production)
# ============================================================================
# Sentry Error Tracking: https://sentry.io
# Get your DSN from Sentry dashboard at: https://sentry.io/settings/[org]/projects/[project]/keys/
# Free tier: 5,000 errors/month
# NEXT_PUBLIC_SENTRY_DSN=https://[key]@[sentry-host].ingest.sentry.io/[project-id]

# CloudWatch Logs (AWS): for centralized logging (optional)
# AWS_REGION=ap-northeast-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Slack Webhook (for alerts): https://api.slack.com/messaging/webhooks
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/[your-webhook-url]
